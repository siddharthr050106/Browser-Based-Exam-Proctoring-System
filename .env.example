# ─── Database ───
DATABASE_URL=postgresql+asyncpg://bezp:bezp_secret@localhost:5432/bezp_db

# ─── Redis ───
REDIS_URL=redis://localhost:6379/0

# ─── MinIO / S3 ───
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=bezp-clips
MINIO_USE_SSL=false

# ─── JWT Auth ───
JWT_SECRET=change-me-to-a-random-64-char-string
JWT_ALGORITHM=HS256
JWT_LIFETIME_SECONDS=3600

# ─── YOLO ───
YOLO_MODEL_PATH=yolov8n.pt
YOLO_CONFIDENCE_THRESHOLD=0.6
YOLO_FPS=5

# ─── Detection Thresholds ───
PHONE_CONSECUTIVE_FRAMES=2
PERSON_CONSECUTIVE_FRAMES=3
NO_FACE_TIMEOUT_SECONDS=5
BACKGROUND_SSIM_THRESHOLD=0.75
BACKGROUND_CHECK_INTERVAL_MINUTES=10
IDENTITY_COSINE_THRESHOLD=0.7
GAZE_YAW_THRESHOLD=30.0
GAZE_PITCH_THRESHOLD=20.0
GAZE_ANOMALY_DURATION_SECONDS=5
TAB_SWITCH_FLAG_COUNT=3
TAB_SWITCH_FLAG_WINDOW_MINUTES=2

# ─── Network Tier Probe ───
NETWORK_PROBE_SIZE_KB=100
NETWORK_PROBE_INTERVAL_SECONDS=30

# ─── App ───
APP_NAME=BEZP
APP_ENV=development
APP_DEBUG=true
CORS_ORIGINS=["http://localhost:5173"]
